# Dograh standalone release bundle
# Copy to .env and edit before first start.

# Version pinning
DOGRAH_VERSION=latest
REGISTRY=ghcr.io/dograh-hq

# Core app
ENVIRONMENT=oss
LOG_LEVEL=INFO
BACKEND_API_ENDPOINT=http://localhost:18000
BACKEND_URL=http://api:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:18000
NEXT_PUBLIC_NODE_ENV=oss
ENABLE_TELEMETRY=false
FASTAPI_WORKERS=1
OSS_JWT_SECRET=change-me-in-production

# Data stores
POSTGRES_PASSWORD=postgres
REDIS_PASSWORD=redissecret
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=voice-audio
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_API_CORS_ALLOW_ORIGIN=https://localhost:3010

# TURN / WebRTC
TURN_HOST=
TURN_SECRET=
FORCE_TURN_RELAY=false

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT=

# Optional Langfuse
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
